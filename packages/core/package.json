{
  "name": "@bhavya-dhoot/cohort-core",
  "version": "0.1.1",
  "description": "Core orchestration engine for Cohort: spawns and manages OpenCode implementation workers in isolated git worktrees, exposed as an MCP server",
  "keywords": [
    "ai-agents",
    "autonomous-agents",
    "claude-code",
    "opencode",
    "multi-agent",
    "orchestration",
    "mcp"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./mcp/bin.js": "./dist/mcp/bin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Bhavya-Dhoot/Cohort.git"
  },
  "homepage": "https://bhavya-dhoot.github.io/Cohort/",
  "bugs": {
    "url": "https://github.com/Bhavya-Dhoot/Cohort/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b .",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.4.3",
    "yaml": "^2.9.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "@types/node": "^22.17.1"
  }
}
